# ========================================
# Activity Monitor - Environment Variables
# ========================================

# Path untuk file database SQLite
# - Jika kosong/tidak diset, otomatis menggunakan "activity-monitor.db" di folder saat ini.
# - Untuk production (seperti Easypanel/Docker dengan volume), arahkan ke folder data yang dipersistenkan.
DB_PATH=/app/data/activity-monitor.db

# (Opsional) Port aplikasi jika kedepannya dikonfigurasi dinamis
# PORT=8080
